#!/bin/sh
# Sautero pre-commit guard (health check 2026-07-15).
# Runs the two auditors that catch this project's actual historical bug classes
# BEFORE anything reaches a commit. CI runs the same checks, so skipping this
# hook locally (--no-verify) only delays the failure, it can't ship it.
set -e
echo "pre-commit: running Sautero auditors…"
python3 scripts/audit_db.py
python3 scripts/audit_app.py
# Money-path calc unit tests — pure, fast. Only when node is present (there is no local JS
# engine on Richard's machine); CI (health-checks + deploy gate) always runs them regardless.
if command -v node >/dev/null 2>&1; then
  node scripts/calc_unit_test.js
else
  echo "pre-commit: node not found — skipping calc unit tests locally (CI still runs them)."
fi
# Worked hours come from git (the real work trail) — rewrite the WORK_HOURS block in every
# source doc so it can never drift or go stale (the 20.7/21.7-missing incident, 21.7.).
python3 scripts/work_hours.py --write
git add "visual data/costs.html" "visual data/tasklist.html" 2>/dev/null || true
# Merged internal docs (produkt/plan/biznis/znacka/poznamky) are GENERATED from the source
# documents — regenerate them here so they can never go stale (17.7. consolidation).
python3 scripts/build_docs.py
git add "visual data/produkt.html" "visual data/plan.html" "visual data/biznis.html" "visual data/znacka.html" "visual data/poznamky.html" 2>/dev/null || true
echo "pre-commit: clean."
