#!/bin/sh
# ChefOS pre-push guard: same auditors as pre-commit (cheap, seconds), plus a
# loud reminder of the deploy contract — pushing main auto-deploys app/ to
# production via GitHub Pages.
set -e
python3 scripts/audit_db.py
python3 scripts/audit_app.py
branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" = "main" ]; then
  echo ""
  echo "⚠️  Pushing MAIN = deploying app/ to production (app.chefos.ch)."
  echo "   Contract (see DEPLOY_CHECKLIST.md): new SQL goes staging-first,"
  echo "   app changes get a live check on a real phone when feasible."
  echo ""
fi
